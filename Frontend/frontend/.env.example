# API Configuration
# ==================
# 
# For local development (web browser on same machine):
# Leave this empty or set to http://localhost:8080
# 
# For mobile or network access (accessing from different machine):
# Set this to the IP address of your backend server
# Example: http://192.168.1.100:8080
# 
# To find your computer's IP address:
# Windows: Open Command Prompt and type: ipconfig
# Mac/Linux: Open Terminal and type: ifconfig
# Look for IPv4 Address (Windows) or inet (Mac/Linux)
#
# For production deployment:
# Set to your production backend URL
#

REACT_APP_API_URL=

# Note: If REACT_APP_API_URL is empty, the app will automatically detect it:
# - On localhost: uses http://localhost:8080
# - On network: uses http://<current-hostname>:8080
